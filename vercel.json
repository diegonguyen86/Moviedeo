{
  "crons": [
    {
      "path": "/api/cron-trending",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/bot",
      "destination": "/api/bot"
    },
    {
      "source": "/phim-proxy/:path*",
      "destination": "https://phimapi.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}